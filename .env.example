# ============================================
# Minivault - Environment Variables
# ============================================

# Server
SERVER_PORT=8081

# Database (own service DB)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/minivault_db
SPRING_DATASOURCE_USERNAME=minivault_user
SPRING_DATASOURCE_PASSWORD=minivault_pass

# Security
BACKUP_API_KEY=your-api-key-here

# Backup directories
# OUTPUT_DIR: usado como destino final quando OUTPUT_STORAGE_TYPE=LOCAL,
# ou como diretorio temporario de estagiamento quando OUTPUT_STORAGE_TYPE=S3
OUTPUT_DIR=/tmp/backups
OUTPUT_TEMP_DIR=/tmp/backup-temp

# Output storage type (LOCAL or S3)
OUTPUT_STORAGE_TYPE=LOCAL
# For S3 output:
OUTPUT_STORAGE_ENDPOINT=http://localhost:9000
OUTPUT_STORAGE_BUCKET=minivault-backups
OUTPUT_STORAGE_ACCESS_KEY=minioadmin
OUTPUT_STORAGE_SECRET_KEY=minioadmin
OUTPUT_STORAGE_REGION=us-east-1
OUTPUT_STORAGE_PATH_STYLE=true

# Schedule
BACKUP_SCHEDULE_ENABLED=true
BACKUP_SCHEDULE_CRON=0 0 2 * * ?

# Scheduled backup target database
SCHEDULED_BACKUP_DB_TYPE=postgresql
SCHEDULED_BACKUP_DB_HOST=localhost
SCHEDULED_BACKUP_DB_PORT=5434
SCHEDULED_BACKUP_DB_NAME=target_db
SCHEDULED_BACKUP_DB_USER=target_user
SCHEDULED_BACKUP_DB_PASSWORD=target_pass

# Origin storage (optional - omit to backup only the database)
# Type: LOCAL or S3
ORIGIN_STORAGE_TYPE=LOCAL
# For LOCAL type:
ORIGIN_STORAGE_LOCAL_PATH=/data/storage
# For S3 type:
ORIGIN_STORAGE_ENDPOINT=http://localhost:9000
ORIGIN_STORAGE_BUCKET=my-bucket
ORIGIN_STORAGE_ACCESS_KEY=minioadmin
ORIGIN_STORAGE_SECRET_KEY=minioadmin
ORIGIN_STORAGE_REGION=us-east-1
ORIGIN_STORAGE_PATH_STYLE=true

# Mail notification
NOTIFICATION_ENABLED=false
NOTIFICATION_MAIL_HOST=smtp.gmail.com
NOTIFICATION_MAIL_PORT=587
NOTIFICATION_MAIL_USERNAME=your@email.com
NOTIFICATION_MAIL_PASSWORD=your-app-password
NOTIFICATION_MAIL_SMTP_AUTH=true
NOTIFICATION_MAIL_SMTP_STARTTLS=true
NOTIFICATION_FROM=minivault@example.com
NOTIFICATION_TO=admin@example.com
NOTIFICATION_ON_SUCCESS=true
NOTIFICATION_ON_FAILURE=true

# Flyway (migrations run automatically)
# No additional config needed - migrations are in classpath:db/migration

# Logging
LOG_LEVEL=DEBUG
